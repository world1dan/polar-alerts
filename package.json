{
    "name": "polar-alerts",
    "version": "0.0.11",
    "description": "Automatic Telegram alerts for Polar events with built-in webhook handling",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "npm run build",
        "dev": "tsc --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "check-types": "tsc --noEmit",
        "format": "prettier --write . --log-level silent"
    },
    "keywords": [
        "polar",
        "telegram",
        "alerts",
        "notifications",
        "webhooks",
        "payments",
        "subscriptions",
        "bot",
        "typescript"
    ],
    "author": "Daniil Prylepa",
    "license": "MIT",
    "dependencies": {
        "date-fns": "^4.4.0",
        "node-telegram-bot-api": "^1.1.2"
    },
    "peerDependencies": {
        "@polar-sh/sdk": ">=0.48.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@polar-sh/sdk": "^0.48.1",
        "@types/node": "^26.1.0",
        "eslint": "^10.6.0",
        "globals": "^17.7.0",
        "jiti": "^2.7.0",
        "prettier": "^3.9.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "zod": "^4.4.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/world1dan/polar-alerts.git"
    },
    "engines": {
        "node": ">=20"
    }
}
